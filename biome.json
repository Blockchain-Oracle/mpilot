{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "root": true,
  "files": {
    "includes": [
      "**",
      "!**/abi",
      "!**/.next",
      "!**/dist",
      "!**/out",
      "!**/*.d.ts",
      "!**/coverage",
      "!**/.turbo",
      "!**/broadcast",
      "!**/.wrangler",
      "!**/node_modules",
      "!pnpm-lock.yaml"
    ],
    "ignoreUnknown": true
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "nursery": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 400,
            "skipBlankLines": false
          }
        }
      },
      "complexity": {
        "noExcessiveLinesPerFunction": {
          "level": "warn",
          "options": {
            "maxLines": 50,
            "skipBlankLines": false,
            "skipIifes": false
          }
        }
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  }
}
