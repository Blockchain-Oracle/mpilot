strict-peer-dependencies=true
auto-install-peers=false
engine-strict=true

# Publishing config (Track 0a, 2026-06-14).
# Token is NEVER hardcoded; readers must set NPM_TOKEN in env (CI secret) or
# rely on user-level ~/.npmrc for local publish. CI publishes via
# `NPM_TOKEN=${{ secrets.NPM_TOKEN }} pnpm publish -r --access public`.
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
@mpilot:registry=https://registry.npmjs.org/
