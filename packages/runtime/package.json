{
  "name": "@concierge/runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@concierge/sdk": "workspace:*",
    "ioredis": "5.11.1",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "tsup": "8.5.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
