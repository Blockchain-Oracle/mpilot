{
  "name": "@concierge/agentkit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@concierge/tools": "workspace:*"
  },
  "peerDependencies": {
    "@coinbase/agentkit": "^0.10.4",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@coinbase/agentkit": "0.10.4",
    "graphql": "16.12.0",
    "tsup": "8.5.0",
    "zod": "4.4.3"
  }
}
