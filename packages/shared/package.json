{
  "name": "@mpilot/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./abi": {
      "types": "./dist/abi/index.d.ts",
      "import": "./dist/abi/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "viem": "^2.52.0"
  },
  "devDependencies": {
    "tsup": "8.5.0",
    "viem": "2.52.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
