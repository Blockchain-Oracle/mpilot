{
  "name": "@concierge-mantle/llm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.104.1",
    "@anthropic-ai/claude-agent-sdk": "0.3.177",
    "@concierge-mantle/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "tsup": "8.5.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
