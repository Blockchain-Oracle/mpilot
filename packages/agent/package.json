{
  "name": "@mpilot/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:e2e": "vitest run src/__tests__/e2e",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@ai-sdk/provider": "3.0.10",
    "@mpilot/llm": "workspace:*",
    "@mpilot/sdk": "workspace:*",
    "@mpilot/shared": "workspace:*",
    "@mpilot/tools": "workspace:*",
    "@mpilot/vercel-ai": "workspace:*",
    "ai": "6.0.199",
    "ioredis": "5.11.1",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "tsup": "8.5.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
