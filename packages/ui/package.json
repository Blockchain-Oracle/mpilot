{
  "name": "@concierge-mantle/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no unit tests yet'",
    "prepare": "tsup",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.5",
    "react": "19.2.7",
    "tsup": "8.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
