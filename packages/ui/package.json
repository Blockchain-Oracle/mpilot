{
  "name": "@concierge-mantle/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "@types/react": "19.2.5",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "20.0.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsup": "8.5.0",
    "vitest": "4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
