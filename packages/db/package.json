{
  "name": "@mpilot/db",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "migrations",
    "drizzle.config.ts",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "prepare": "tsup",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "drizzle-orm": "0.36.4",
    "pg": "8.13.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.28.1",
    "tsup": "8.5.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
