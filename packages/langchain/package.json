{
  "name": "@mpilot/langchain",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@mpilot/tools": "workspace:*"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@langchain/core": "1.1.48",
    "tsup": "8.5.0",
    "zod": "4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
