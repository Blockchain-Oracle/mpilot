{
  "name": "@concierge-mantle/mcp",
  "version": "0.0.0",
  "description": "MCP server for Concierge — autonomous DeFi agent for Mantle. Stdio-first (`npx -y @concierge-mantle/mcp`) + optional hosted Worker.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blockchain-Oracle/concierge.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://concierge.xyz",
  "keywords": [
    "mcp",
    "mantle",
    "defi",
    "concierge",
    "anthropic",
    "stdio"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "import": "./dist/stdio.js"
    },
    "./streamable-http": {
      "types": "./dist/streamable-http.d.ts",
      "import": "./dist/streamable-http.js"
    },
    "./tools/read": {
      "types": "./dist/tools/read/index.d.ts",
      "import": "./dist/tools/read/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "concierge-mcp": "./dist/stdio.js"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build",
    "prepublishOnly": "node -e \"const fs=require('node:fs');const v=JSON.parse(fs.readFileSync('./package.json','utf8')).version;const stable=/^\\\\d+\\\\.\\\\d+\\\\.\\\\d+$/.test(v);const tag=process.env.npm_config_tag;if(!stable&&tag!=='next'){console.error('[concierge-mcp] FATAL: non-stable version '+v+' must be published with --tag next (got tag='+(tag||'latest')+'). Refusing to clobber the latest dist-tag.');process.exit(1)}\""
  },
  "dependencies": {
    "@concierge-mantle/attestation": "workspace:*",
    "@concierge-mantle/sdk": "workspace:*",
    "@concierge-mantle/shared": "workspace:*",
    "@concierge-mantle/tools": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "happy-dom": "^20.10.3",
    "tsup": "8.5.0"
  }
}
