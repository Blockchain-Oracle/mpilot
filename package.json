{
  "name": "concierge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Autonomous AI agent for Mantle DeFi — composable primitive across web app + MCP server + Agent Skill + npm SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Blockchain-Oracle/concierge.git"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "check": "biome check .",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "loc:check": "node scripts/check-file-loc.mjs",
    "loc:test": "node scripts/test-check-file-loc.mjs",
    "tsconfig:test": "node scripts/test-tsconfig-strict.mjs",
    "slither:test": "node scripts/test-slither-config.mjs",
    "gitleaks:test": "node scripts/test-gitleaks-config.mjs",
    "commitlint:test": "node scripts/test-commitlint-config.mjs",
    "husky:test": "node scripts/test-husky-hooks.mjs",
    "security:test": "node scripts/test-security-workflow.mjs",
    "test:config": "pnpm run husky:test && pnpm run commitlint:test && pnpm run gitleaks:test && pnpm run security:test && pnpm run slither:test && pnpm run loc:test && pnpm run tsconfig:test",
    "typecheck": "tsc -b --noEmit",
    "test": "pnpm -r run test",
    "build": "pnpm -r --workspace-concurrency=1 --if-present run build",
    "dev": "echo '[stub] pnpm --filter ./apps/web dev — wired in story-100' && exit 0",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "22.10.5",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "typescript": "6.0.3",
    "viem": "2.52.2",
    "vitest": "4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
