# Concierge — MCP server (stdio + Cloudflare Worker) environment variables
# Copy to .env (git-ignored) and fill in real values.
# All vars without a default are REQUIRED for the server to start.
#
# Stdio transport: stdout is RESERVED for MCP protocol — logs go to stderr.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Anthropic API key — must start with "sk-ant-"
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ── Database + cache ──────────────────────────────────────────────────────────
# Neon Postgres connection string
DATABASE_URL=postgres://user:pass@host/concierge

# Upstash Redis connection string
REDIS_URL=redis://default:YOUR_PASSWORD@host:6379

# ── Mantle network ────────────────────────────────────────────────────────────
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz

# Chain to connect to: 5000 (mainnet) or 5003 (Sepolia testnet)
MANTLE_CHAIN_ID=5000

# ── Smart account (ZeroDev + Pimlico) — optional, required for E4 ────────────
# ZERODEV_PROJECT_ID=your-project-id
# PIMLICO_API_KEY=your-pimlico-api-key

# ── Externals — optional ──────────────────────────────────────────────────────
# LIFI_API_KEY=your-lifi-key
# PINATA_JWT=your-pinata-jwt
# WEB3_STORAGE_TOKEN=your-w3s-token

# ── Observability — optional ──────────────────────────────────────────────────
# SENTRY_DSN=https://key@sentry.io/project

# ── Auth (Privy) — used when MCP server handles wallet-connect handoff ────────
# PRIVY_APP_ID=your-privy-app-id
# PRIVY_SERVER_KEY=your-privy-server-key

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
